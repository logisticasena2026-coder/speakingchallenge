generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                 String                    @id @default(uuid())
  name               String                    @unique
  email              String                    @unique
  password           String
  avatar             String?
  skin               Skin?
  nivel              Nivel                     @default(PRINCIPIANTE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  dias_racha         Int                       @default(0)
  racha_mas_larga    Int                       @default(0)
  ultima_racha_fecha DateTime?
  ultima_sesion      DateTime?
  fecha_nacimiento   DateTime?
  sexo               String?
  frases             Int                       @default(0)
  precicion_global   Float                     @default(0)
  tiempo_promedio    Float                     @default(0)
  cantidad_logros    Int                       @default(0)
  rol                Rol                       @default(ESTUDIANTE)
  codigo_profesor    String?                   @unique
  tokenReset         ResetearContrasenaToken[]
  sesiones           Session[]
  progreso_frases           ProgresoFraseEstudiante[]
  progreso_frases_nivel     ProgresoFraseNivelEstudiante[]
  progreso_usuario          ProgresoUsuario?
  niveles_completados   NivelCompletado[]
  imperios_completados  ImperioCompletado[]
  eras_completadas      EraCompletada[]
  profesores_asignados    EstudianteProfesor[] @relation("EPEstudiante")
  estudiantes_asignados   EstudianteProfesor[] @relation("EPProfesor")
  logros_desbloqueados LogroDesbloqueado[]
  examenes_creados   Examen[]
  grupos_creados     Grupo[]
  grupos_membresias  GrupoEstudiante[]
  respuestas_examen  RespuestaEstudiante[]
  asignaciones_recibidas AsignacionExamen[]    @relation("AEStudent")
  palabras_guardadas PalabraGuardada[]

  @@unique([name, email])
  @@index([email, name, nivel])
  @@index([codigo_profesor])
}

model EstudianteProfesor {
  id            String   @id @default(uuid())
  estudiante_id String
  profesor_id   String
  assignedAt    DateTime @default(now())

  estudiante user @relation("EPEstudiante", fields: [estudiante_id], references: [id], onDelete: Cascade)
  profesor   user @relation("EPProfesor", fields: [profesor_id], references: [id], onDelete: Cascade)

  @@unique([estudiante_id, profesor_id])
  @@index([estudiante_id])
  @@index([profesor_id])
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([expiresAt, propietario_id])
}

model ResetearContrasenaToken {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([token, propietario_id])
}

model FrasesDePractica {
  id           Int       @id @default(autoincrement())
  fraseIngles  String
  fraseEspanol String
  dificultad   Int
  creador      String
  edad         Int?
  tematica     String
  Escala       String?   @db.Char(2)
  Idioma       String?   @db.Char(15)
  Fec_Alta     DateTime? @default(now()) @db.Date

  progreso     ProgresoFraseEstudiante[]

  @@index([dificultad, tematica, edad, creador])
}

model FraseNivel {
  id           Int       @id @default(autoincrement())
  fraseIngles  String
  fraseEspanol String
  dificultad   Int
  creador      String
  edad         Int?
  tematica     String
  Fec_Alta     DateTime? @default(now()) @db.Date
  nivel_id     String
  nivel        NivelProgresion @relation(fields: [nivel_id], references: [id], onDelete: Cascade)

  progreso     ProgresoFraseNivelEstudiante[]

  @@index([nivel_id])
}

model ProgresoFraseEstudiante {
  id            String   @id @default(uuid())
  estudiante_id String
  frase_id      Int
  precision     Float
  tiempo        Int
  intentos      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  estudiante user              @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  frase      FrasesDePractica  @relation(fields: [frase_id], references: [id], onDelete: Cascade)

  @@unique([estudiante_id, frase_id])
  @@index([estudiante_id])
  @@index([frase_id])
}

model ProgresoFraseNivelEstudiante {
  id            String   @id @default(uuid())
  estudiante_id String
  frase_id      Int
  precision     Float
  tiempo        Int
  intentos      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  estudiante user       @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  frase      FraseNivel @relation(fields: [frase_id], references: [id], onDelete: Cascade)

  @@unique([estudiante_id, frase_id])
  @@index([estudiante_id])
  @@index([frase_id])
}

model Examen {
  id           String   @id @default(uuid())
  titulo       String
  descripcion  String?
  profesor_id  String
  profesor     user     @relation(fields: [profesor_id], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  preguntas    Pregunta[]
  asignaciones AsignacionExamen[]

  @@unique([profesor_id, titulo])
  @@index([profesor_id])
}

model Pregunta {
  id                 String        @id @default(uuid())
  examen_id          String
  examen             Examen        @relation(fields: [examen_id], references: [id], onDelete: Cascade)
  tipo               TipoPregunta
  pregunta           String
  opciones           Json?
  respuesta_correcta String
  orden              Int           @default(0)
  createdAt          DateTime      @default(now())

  respuestas         RespuestaEstudiante[]

  @@index([examen_id])
}

model Grupo {
  id           String   @id @default(uuid())
  nombre       String
  profesor_id  String
  profesor     user     @relation(fields: [profesor_id], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  miembros     GrupoEstudiante[]
  asignaciones AsignacionExamen[]

  @@unique([profesor_id, nombre])
  @@index([profesor_id])
}

model GrupoEstudiante {
  id            String   @id @default(uuid())
  grupo_id      String
  grupo         Grupo    @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  estudiante_id String
  estudiante    user     @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  assignedAt    DateTime @default(now())

  @@unique([grupo_id, estudiante_id])
  @@index([estudiante_id])
}

model AsignacionExamen {
  id               String   @id @default(uuid())
  examen_id        String
  examen           Examen   @relation(fields: [examen_id], references: [id], onDelete: Cascade)
  grupo_id         String?
  grupo            Grupo?   @relation(fields: [grupo_id], references: [id], onDelete: SetNull)
  estudiante_id    String?
  estudiante       user?    @relation("AEStudent", fields: [estudiante_id], references: [id], onDelete: Cascade)
  fecha_asignacion DateTime @default(now())
  fecha_limite     DateTime?

  @@unique([examen_id, grupo_id])
  @@index([examen_id])
  @@index([grupo_id])
  @@index([estudiante_id])
}

model RespuestaEstudiante {
  id            String   @id @default(uuid())
  estudiante_id String
  estudiante    user     @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  pregunta_id   String
  pregunta      Pregunta @relation(fields: [pregunta_id], references: [id], onDelete: Cascade)
  respuesta     String
  correcta      Boolean
  createdAt     DateTime @default(now())

  @@unique([estudiante_id, pregunta_id])
  @@index([estudiante_id])
  @@index([pregunta_id])
}

model PalabraGuardada {
  id            String   @id @default(uuid())
  usuario_id    String
  usuario       user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  palabra       String
  traduccion    String
  contexto      String?
  created_at    DateTime @default(now())

  @@unique([usuario_id, palabra])
  @@index([usuario_id])
}

enum Rol {
  ESTUDIANTE
  PROFESOR
  ADMIN
}

enum Nivel {
  PRINCIPIANTE
  BASICO
  BASICO_INTERMEDIO
  INTERMEDIO
  AVANZADO
}

enum TipoPregunta {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

model Era {
  id        String   @id @default(uuid())
  nombre    String   @unique
  orden     Int      @unique
  color     String
  createdAt DateTime @default(now())

  imperios   Imperio[]
  progreso   ProgresoUsuario[]
  completadas EraCompletada[]
}

model Imperio {
  id                        String   @id @default(uuid())
  era_id                    String
  era                       Era      @relation(fields: [era_id], references: [id], onDelete: Cascade)
  nombre                    String
  orden                     Int
  frases_propias            Int      @default(0)
  frases_para_desbloquear   Int      @default(0)
  porcentaje_aprobacion     Float    @default(0)
  umbral_bronce             Float    @default(65)
  umbral_plata              Float    @default(75)
  umbral_oro                Float    @default(98)
  skin                      Skin?
  createdAt                 DateTime @default(now())

  niveles     NivelProgresion[]
  progreso    ProgresoUsuario[]
  completados ImperioCompletado[]

  @@unique([era_id, nombre])
  @@unique([era_id, orden])
}

model NivelProgresion {
  id         String   @id @default(uuid())
  imperio_id String
  imperio    Imperio  @relation(fields: [imperio_id], references: [id], onDelete: Cascade)
  orden      Int
  createdAt  DateTime @default(now())

  frases_nivel FraseNivel[]
  progreso     ProgresoUsuario[]
  completado   NivelCompletado[]

  @@unique([imperio_id, orden])
}

model ProgresoUsuario {
  id                String   @id @default(uuid())
  usuario_id        String   @unique
  usuario           user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  era_actual_id     String
  era_actual        Era      @relation(fields: [era_actual_id], references: [id])
  imperio_actual_id String
  imperio_actual    Imperio  @relation(fields: [imperio_actual_id], references: [id])
  nivel_actual_id   String
  nivel_actual      NivelProgresion @relation(fields: [nivel_actual_id], references: [id])
  estrato_social    Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@index([usuario_id])
}

model NivelCompletado {
  id                 String   @id @default(uuid())
  usuario_id         String
  usuario            user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  nivel_id           String
  nivel              NivelProgresion @relation(fields: [nivel_id], references: [id], onDelete: Cascade)
  precision_promedio Float    @default(0)
  created_at         DateTime @default(now())

  @@unique([usuario_id, nivel_id])
}

model ImperioCompletado {
  id                 String   @id @default(uuid())
  usuario_id         String
  usuario            user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  imperio_id         String
  imperio            Imperio  @relation(fields: [imperio_id], references: [id], onDelete: Cascade)
  insignia           Insignia @default(NINGUNA)
  precision_promedio Float    @default(0)
  created_at         DateTime @default(now())

  @@unique([usuario_id, imperio_id])
}

model EraCompletada {
  id         String   @id @default(uuid())
  usuario_id String
  usuario    user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  era_id     String
  era        Era      @relation(fields: [era_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([usuario_id, era_id])
}

enum Insignia {
  NINGUNA
  BRONCE
  PLATA
  ORO
}

enum TipoCondicionLogro {
  NIVELES_COMPLETADOS
  FRASES_TOTALES
  RACHA_DIAS
  IMPERIOS_COMPLETADOS
  IMPERIOS_INSIGNIA_BRONCE
  IMPERIOS_INSIGNIA_ORO
  ERAS_COMPLETADAS
  PRECISION_GLOBAL
  ESTRATO_SOCIAL
}

model Logro {
  id          String               @id @default(uuid())
  nombre      String               @unique
  descripcion String
  icono       String
  tipo        TipoCondicionLogro
  valor       Int
  created_at  DateTime             @default(now())

  desbloqueos LogroDesbloqueado[]
}

model LogroDesbloqueado {
  id         String   @id @default(uuid())
  usuario_id String
  usuario    user     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  logro_id   String
  logro      Logro    @relation(fields: [logro_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([usuario_id, logro_id])
  @@index([usuario_id])
}

enum Skin {
  ImperioAcadio
  ImperioAntiguoDeEgipto
  ImperioHitita
  ImperioAsirio
  ImperioMacedonio
  ImperioMaurya
  ImperioCartagines
  ImperioRomano
  ImperioBizantino
  CalifatoOmeya
  ImperioMongol
  ImperioOtomano
  ImperioAzteca
  ImperioInca
  ImperioRuso
  ImperioSatoshi
  ImperioEthereum
  ImperioSolariaChain
  ImperioQuantumLedger
  ImperioNexusAI
  ImperioTitanVanguard
  ImperioCyberAnunnaki
  ImperioAtlantechPrime
  ImperioOmegaCyborg
  ImperioBabilonico
  ImperioNeobabilonico
  ImperioPersa
  ImperioBritanico
  ImperioJapones
  GuardianesDelPacifico
}
