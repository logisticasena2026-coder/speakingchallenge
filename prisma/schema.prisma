generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                 String                    @id @default(uuid())
  name               String                    @unique
  email              String                    @unique
  password           String
  avatar             String?
  skin               Skin?
  nivel              Nivel                     @default(PRINCIPIANTE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  dias_racha         Int                       @default(0)
  racha_mas_larga    Int                       @default(0)
  ultima_racha_fecha DateTime?
  ultima_sesion      DateTime?
  frases             Int                       @default(0)
  precicion_global   Float                     @default(0)
  tiempo_promedio    Float                     @default(0)
  cantidad_logros    Int                       @default(0)
  tokenReset         ResetearContrasenaToken[]
  sesiones           Session[]

  @@unique([name, email])
  @@index([email, name, nivel])
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([expiresAt, propietario_id])
}

model ResetearContrasenaToken {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([token, propietario_id])
}

model FrasesDePractica {
  id           Int       @id @default(autoincrement())
  fraseIngles  String    
  fraseEspanol String
  dificultad   Int
  creador      String
  edad         Int?
  tematica     String
  Escala       String?   @db.Char(2)
  Idioma       String?   @db.Char(15)
  Fec_Alta     DateTime? @default(now()) @db.Date

  @@index([dificultad, tematica, edad, creador])
}

enum Nivel {
  PRINCIPIANTE
  BASICO
  BASICO_INTERMEDIO
  INTERMEDIO
  AVANZADO
}

enum Skin {
  // ImperioCivilización
  ImperioAcadio
  ImperioAntiguoDeEgipto
  // ImperioBabilónico
  ImperioHitita
  ImperioAsirio
  // ImperioNeobabilónico
  // ImperioAqueménidaPersa
  ImperioMacedonio
  ImperioMaurya
  ImperioRomano
  ImperioBizantino
  CalifatoOmeya
  ImperioMongol
  ImperioOtomano
  ImperioAzteca
  ImperioInca
  ImperioRuso
  // ImperioBritánico
  // ImperioJaponés
  // ImperioCartaginés
  ImperioSatoshi
  ImperioEthereum
  ImperioSolariaChain
  ImperioQuantumLedger
  ImperioNexusAI
