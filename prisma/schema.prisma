generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                 String                    @id @default(uuid())
  name               String                    @unique
  email              String                    @unique
  password           String
  avatar             String?
  skin               Skin?
  nivel              Nivel                     @default(PRINCIPIANTE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  dias_racha         Int                       @default(0)
  racha_mas_larga    Int                       @default(0)
  ultima_racha_fecha DateTime?
  ultima_sesion      DateTime?
  frases             Int                       @default(0)
  precicion_global   Float                     @default(0)
  tiempo_promedio    Float                     @default(0)
  cantidad_logros    Int                       @default(0)
  rol                Rol                       @default(ESTUDIANTE)
  codigo_profesor    String?                   @unique
  tokenReset         ResetearContrasenaToken[]
  sesiones           Session[]
  progreso_frases    ProgresoFraseEstudiante[]
  profesores_asignados    EstudianteProfesor[] @relation("EPEstudiante")
  estudiantes_asignados   EstudianteProfesor[] @relation("EPProfesor")
  examenes_creados   Examen[]
  grupos_creados     Grupo[]
  grupos_membresias  GrupoEstudiante[]
  respuestas_examen  RespuestaEstudiante[]
  asignaciones_recibidas AsignacionExamen[]    @relation("AEStudent")

  @@unique([name, email])
  @@index([email, name, nivel])
  @@index([codigo_profesor])
}

model EstudianteProfesor {
  id            String   @id @default(uuid())
  estudiante_id String
  profesor_id   String
  assignedAt    DateTime @default(now())

  estudiante user @relation("EPEstudiante", fields: [estudiante_id], references: [id], onDelete: Cascade)
  profesor   user @relation("EPProfesor", fields: [profesor_id], references: [id], onDelete: Cascade)

  @@unique([estudiante_id, profesor_id])
  @@index([estudiante_id])
  @@index([profesor_id])
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([expiresAt, propietario_id])
}

model ResetearContrasenaToken {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  propietario_id String?
  propietario    user?    @relation(fields: [propietario_id], references: [id], onDelete: Cascade)

  @@index([token, propietario_id])
}

model FrasesDePractica {
  id           Int       @id @default(autoincrement())
  fraseIngles  String
  fraseEspanol String
  dificultad   Int
  creador      String
  edad         Int?
  tematica     String
  Escala       String?   @db.Char(2)
  Idioma       String?   @db.Char(15)
  Fec_Alta     DateTime? @default(now()) @db.Date

  progreso       ProgresoFraseEstudiante[]

  @@index([dificultad, tematica, edad, creador])
}

model ProgresoFraseEstudiante {
  id            String   @id @default(uuid())
  estudiante_id String
  frase_id      Int
  precision     Float
  tiempo        Int
  intentos      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  estudiante user            @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  frase      FrasesDePractica @relation(fields: [frase_id], references: [id], onDelete: Cascade)

  @@unique([estudiante_id, frase_id])
  @@index([estudiante_id])
  @@index([frase_id])
}

model Examen {
  id           String   @id @default(uuid())
  titulo       String
  descripcion  String?
  profesor_id  String
  profesor     user     @relation(fields: [profesor_id], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  preguntas    Pregunta[]
  asignaciones AsignacionExamen[]

  @@unique([profesor_id, titulo])
  @@index([profesor_id])
}

model Pregunta {
  id                 String        @id @default(uuid())
  examen_id          String
  examen             Examen        @relation(fields: [examen_id], references: [id], onDelete: Cascade)
  tipo               TipoPregunta
  pregunta           String
  opciones           Json?
  respuesta_correcta String
  orden              Int           @default(0)
  createdAt          DateTime      @default(now())

  respuestas         RespuestaEstudiante[]

  @@index([examen_id])
}

model Grupo {
  id           String   @id @default(uuid())
  nombre       String
  profesor_id  String
  profesor     user     @relation(fields: [profesor_id], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  miembros     GrupoEstudiante[]
  asignaciones AsignacionExamen[]

  @@unique([profesor_id, nombre])
  @@index([profesor_id])
}

model GrupoEstudiante {
  id            String   @id @default(uuid())
  grupo_id      String
  grupo         Grupo    @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  estudiante_id String
  estudiante    user     @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  assignedAt    DateTime @default(now())

  @@unique([grupo_id, estudiante_id])
  @@index([estudiante_id])
}

model AsignacionExamen {
  id               String   @id @default(uuid())
  examen_id        String
  examen           Examen   @relation(fields: [examen_id], references: [id], onDelete: Cascade)
  grupo_id         String?
  grupo            Grupo?   @relation(fields: [grupo_id], references: [id], onDelete: SetNull)
  estudiante_id    String?
  estudiante       user?    @relation("AEStudent", fields: [estudiante_id], references: [id], onDelete: Cascade)
  fecha_asignacion DateTime @default(now())
  fecha_limite     DateTime?

  @@unique([examen_id, grupo_id])
  @@index([examen_id])
  @@index([grupo_id])
  @@index([estudiante_id])
}

model RespuestaEstudiante {
  id            String   @id @default(uuid())
  estudiante_id String
  estudiante    user     @relation(fields: [estudiante_id], references: [id], onDelete: Cascade)
  pregunta_id   String
  pregunta      Pregunta @relation(fields: [pregunta_id], references: [id], onDelete: Cascade)
  respuesta     String
  correcta      Boolean
  createdAt     DateTime @default(now())

  @@unique([estudiante_id, pregunta_id])
  @@index([estudiante_id])
  @@index([pregunta_id])
}

enum Rol {
  ESTUDIANTE
  PROFESOR
  ADMIN
}

enum Nivel {
  PRINCIPIANTE
  BASICO
  BASICO_INTERMEDIO
  INTERMEDIO
  AVANZADO
}

enum TipoPregunta {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum Skin {
  ImperioAcadio
  ImperioAntiguoDeEgipto
  ImperioHitita
  ImperioAsirio
  ImperioMacedonio
  ImperioMaurya
  ImperioRomano
  ImperioBizantino
  CalifatoOmeya
  ImperioMongol
  ImperioOtomano
  ImperioAzteca
  ImperioInca
  ImperioRuso
  ImperioSatoshi
  ImperioEthereum
  ImperioSolariaChain
  ImperioQuantumLedger
  ImperioNexusAI
  ImperioTitanVanguard
  ImperioCyberAnunnaki
  ImperioAtlantechPrime
  ImperioOmegaCyborg
}
